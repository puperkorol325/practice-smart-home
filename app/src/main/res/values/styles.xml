<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.Auth.Button.Primary" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_auth_button_primary</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/auth_button_text_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Widget.Auth.Button.Secondary" parent="Widget.Auth.Button.Primary">
        <item name="android:background">@drawable/bg_auth_button_secondary</item>
    </style>

    <style name="Widget.Pin.Key" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:background">@drawable/bg_pin_key</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">@dimen/pin_key_text_size</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

</resources>
