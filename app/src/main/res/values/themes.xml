<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Practice_house" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Practice_house" parent="Base.Theme.Practice_house" />

    <style name="Theme.Practice_house.Loading" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/loading_screen_background</item>
        <item name="android:statusBarColor">@color/loading_screen_background</item>
        <item name="android:navigationBarColor">@color/loading_screen_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.Practice_house.Auth" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/auth_secondary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>